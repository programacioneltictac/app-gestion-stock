# Configuración de la base de datos local
DB_USER=
DB_HOST=
DB_NAME=
DB_PASSWORD=
DB_PORT=

# URL de la base de datos 
DATABASE_URL=

# Nuevas variables de seguridad
JWT_SECRET=
USE_NEW_AUTH=  # Cambiar a true cuando esté listo

# Opcional
NODE_ENV=

PORT=

# Configuración de Rate Limiting (opcional - valores por defecto)
LOGIN_RATE_LIMIT_WINDOW_MS=
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=
API_RATE_LIMIT_WINDOW_MS=
API_RATE_LIMIT_MAX_REQUESTS=

# Configuración de Logs (para futuras implementaciones)
LOG_LEVEL=
ENABLE_AUDIT_LOG=

# Configuración de Seguridad adicional (opcional)
BCRYPT_ROUNDS=
JWT_EXPIRES_IN=
MAX_JSON_PAYLOAD_SIZE=

# Filtro de stock para sync con API externa.
# Valores: 'stockmayoracero' (recomendado, solo stock > 0)
#          'todos' (catálogo completo, mucho más lento)
SYNC_STOCK_FILTER=

# Cantidad de sucursales a sincronizar en paralelo (default: 3).
# Subir solo si la API externa lo tolera. Cada sucursal consume 1 conexión del pool.
SYNC_CONCURRENCY=

# Pausa en milisegundos entre requests consecutivos a la API (dentro de una misma sucursal).
# Sirve para no saturar al proveedor externo. Default: 0 (sin pausa).
SYNC_REQUEST_DELAY_MS=